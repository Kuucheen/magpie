# Required: used to encrypt stored proxy secrets.
# Keep it stable between restarts/updates or previously stored secrets can't be decrypted.
PROXY_ENCRYPTION_KEY=ChangeMeToAStrongKey
JWT_SECRET=ChangeMeToo

# Optional: multi-instance rotating proxy identity (recommended when running multiple backend instances).
# Keep MAGPIE_INSTANCE_ID stable for each instance.
# MAGPIE_INSTANCE_ID=proxy-node-1
# MAGPIE_INSTANCE_NAME=Proxy Node 1
# MAGPIE_INSTANCE_REGION=us-east-1

# Optional: rotating proxy listener settings.
# ROTATING_PROXY_PORT_START=20000
# ROTATING_PROXY_PORT_END=20100
# ROTATING_PROXY_SYNC_INTERVAL_SECONDS=10

# Optional: API hardening settings.
# CORS_ALLOWED_ORIGINS=http://localhost:5050,http://127.0.0.1:5050
# SERVER_READ_TIMEOUT_SECONDS=30
# SERVER_READ_HEADER_TIMEOUT_SECONDS=10
# SERVER_WRITE_TIMEOUT_SECONDS=30
# SERVER_IDLE_TIMEOUT_SECONDS=120
# API_UPLOAD_MAX_BODY_BYTES=10485760
# API_JSON_MAX_BODY_BYTES=1048576
# API_MULTIPART_MEMORY_BYTES=1048576

# Optional: proxy statistics retention controls.
# Set *_DAYS to 0 to disable that retention action.
# PROXY_STATISTICS_RETENTION_DAYS=30
# PROXY_STATISTICS_RESPONSE_RETENTION_DAYS=7
# PROXY_STATISTICS_RETENTION_INTERVAL=1h
# PROXY_STATISTICS_RETENTION_INTERVAL_MINUTES=60
# PROXY_STATISTICS_RETENTION_BATCH_SIZE=5000
# PROXY_STATISTICS_RETENTION_MAX_BATCHES=12
