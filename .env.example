# Required: used to encrypt stored proxy secrets.
# Keep it stable between restarts/updates or previously stored secrets can't be decrypted.
PROXY_ENCRYPTION_KEY=ChangeMeToAStrongKey
JWT_SECRET=ChangeMeToo
# Optional: strict startup validation for JWT_SECRET and PROXY_ENCRYPTION_KEY.
# Defaults to false locally and true when backend runs with -production.
# STRICT_SECRET_VALIDATION=true
# Optional overrides for Docker Compose database setup.
# If unset, Compose defaults to DB_USERNAME=magpie_user and DB_PASSWORD=ChangeMeToAStrongDbPassword.
DB_USERNAME=magpie_user
DB_PASSWORD=ChangeMeToAStrongDbPassword
# Optional database name (defaults to magpie in Compose if omitted).
# DB_NAME=magpie
# Optional schema migration toggle.
# Defaults to true locally and false when backend runs with -production.
# Multi-instance deployments: keep DB_AUTO_MIGRATE consistent across all instances.
# DB_AUTO_MIGRATE=true
# LOG_LEVEL=info
# DB_SSLMODE=require

# Optional: multi-instance rotating proxy identity (recommended when running multiple backend instances).
# Keep MAGPIE_INSTANCE_ID stable for each instance.
# MAGPIE_INSTANCE_ID=proxy-node-1
# MAGPIE_INSTANCE_NAME=Proxy Node 1
# MAGPIE_INSTANCE_REGION=us-east-1

# Optional: rotating proxy listener settings.
# ROTATING_PROXY_PORT_START=20000
# ROTATING_PROXY_PORT_END=20100
# ROTATING_PROXY_SYNC_INTERVAL_SECONDS=10

# Optional: API hardening settings.
# CORS_ALLOWED_ORIGINS=http://localhost:5050,http://127.0.0.1:5050
# SERVER_READ_TIMEOUT_SECONDS=30
# SERVER_READ_HEADER_TIMEOUT_SECONDS=10
# SERVER_WRITE_TIMEOUT_SECONDS=30
# SERVER_IDLE_TIMEOUT_SECONDS=120
# SERVER_SHUTDOWN_TIMEOUT_SECONDS=20
# API_UPLOAD_MAX_BODY_BYTES=10485760
# API_JSON_MAX_BODY_BYTES=1048576
# API_MULTIPART_MEMORY_BYTES=1048576
# Optional: trust forwarded client IP headers only from these immediate proxy CIDRs.
# If unset, X-Forwarded-For/X-Real-IP are ignored and RemoteAddr is used.
# Multi-instance deployments: keep TRUSTED_PROXY_CIDRS consistent across all instances.
# TRUSTED_PROXY_CIDRS=10.0.0.0/8,192.168.0.0/16

# Local default: first registered user becomes admin and public /api/register is enabled.
# Production defaults when backend runs with -production:
#   DISABLE_PUBLIC_REGISTRATION=true
#   ENABLE_PUBLIC_FIRST_ADMIN_BOOTSTRAP=false
# Set ENABLE_PUBLIC_FIRST_ADMIN_BOOTSTRAP=true only for controlled first-admin bootstrap windows.
# Multi-instance deployments: keep DISABLE_PUBLIC_REGISTRATION and
# ENABLE_PUBLIC_FIRST_ADMIN_BOOTSTRAP consistent across all backend instances.
# DISABLE_PUBLIC_REGISTRATION=true
# ENABLE_PUBLIC_FIRST_ADMIN_BOOTSTRAP=false

# Optional: readiness behavior.
# If true, /readyz returns degraded (200) when Redis is unavailable but DB/startup bootstrap are healthy.
# READYZ_ALLOW_REDIS_DEGRADED=false

# Optional: Docker Compose resource tuning.
# BACKEND_CPU_LIMIT=2.00
# BACKEND_MEMORY_LIMIT=1G
# BACKEND_CPU_RESERVATION=0.50
# BACKEND_MEMORY_RESERVATION=256M
# FRONTEND_CPU_LIMIT=1.00
# FRONTEND_MEMORY_LIMIT=512M
# FRONTEND_CPU_RESERVATION=0.25
# FRONTEND_MEMORY_RESERVATION=128M
# POSTGRES_CPU_LIMIT=1.50
# POSTGRES_MEMORY_LIMIT=1G
# POSTGRES_CPU_RESERVATION=0.50
# POSTGRES_MEMORY_RESERVATION=256M
# REDIS_CPU_LIMIT=1.00
# REDIS_MEMORY_LIMIT=512M
# REDIS_CPU_RESERVATION=0.25
# REDIS_MEMORY_RESERVATION=128M

# Optional: proxy statistics retention controls.
# Set *_DAYS to 0 to disable that retention action.
# PROXY_STATISTICS_RETENTION_DAYS=30
# PROXY_STATISTICS_RESPONSE_RETENTION_DAYS=7
# PROXY_STATISTICS_RETENTION_INTERVAL=1h
# PROXY_STATISTICS_RETENTION_INTERVAL_MINUTES=60
# PROXY_STATISTICS_RETENTION_BATCH_SIZE=5000
# PROXY_STATISTICS_RETENTION_MAX_BATCHES=12
